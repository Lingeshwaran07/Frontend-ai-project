#!/usr/bin/env sh

# Read the commit message file
commit_msg_file=$1
commit_msg=$(cat "$commit_msg_file" | sed '/^#/d' | sed '/^$/d' | head -1)

# Check if commit message is empty
if [ -z "$commit_msg" ]; then
    echo "❌ Error: Commit message cannot be empty"
    exit 1
fi

# Check minimum length
msg_len=${#commit_msg}
if [ $msg_len -lt 10 ]; then
    echo "❌ Error: Commit message too short (minimum 10 characters, got $msg_len)"
    exit 1
fi

# Check maximum length
if [ $msg_len -gt 100 ]; then
    echo "❌ Error: Commit message too long (maximum 100 characters, got $msg_len)"
    exit 1
fi

# Check if message starts with capital letter or conventional commit type
if ! echo "$commit_msg" | grep -qE "^([A-Z]|feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert)"; then
    echo "❌ Error: Commit message must start with a capital letter or conventional commit type"
    echo "   Examples:"
    echo "   - 'Add new feature'"
    echo "   - 'feat: add user authentication'"
    echo "   - 'fix: resolve login bug'"
    exit 1
fi

echo "✅ Commit message validation passed"
exit 0